# direnv: auto-enter the Nix flake devShell on cd (requires nix-direnv).
#   https://github.com/nix-community/nix-direnv
# After editing, run: direnv allow
use flake

# Load local, git-ignored overrides (e.g. MEDIA_DIR, DATA_DIR, COOKIES_FILE)
# if a .env is present. Optional.
dotenv_if_exists .env
